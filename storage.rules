rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /section-images/{sectionId}/{subId}/{filename} {
      allow read: if request.auth != null;
      allow write, delete: if request.auth != null
        && (firestore.get(
              /databases/(default)/documents/users/$(request.auth.uid)
            ).data.role_academichub == 'academic_admin'
           || firestore.get(
                /databases/(default)/documents/users/$(request.auth.uid)
              ).data.role_centralhub == 'central_admin');
    }
    match /pacing-assessments/{collection}/{chapterId}/{filename} {
      allow read: if request.auth != null;
      allow write, delete: if request.auth != null
        && firestore.get(
             /databases/(default)/documents/users/$(request.auth.uid)
           ).data.role_centralhub == 'central_admin';
    }
    // Orientation page is public — allow unauthenticated photo uploads (images, max 5 MB)
    match /orientation_photos/{filename} {
      allow read: if true;
      allow write: if request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if false;
    }

    // Competency evidence uploads (Teachers Hub + Academic Hub portfolios).
    // Path: competency_evidence/{platform}/{uid}/{timestamp}_{filename}
    //   - {platform} = 'teachers' | 'academic'
    //   - {uid}      = the submitting user's auth uid
    // Owner uploads up to 25 MB per file. central_admin can read/delete for review.
    match /competency_evidence/{platform}/{uid}/{filename} {
      allow read: if request.auth != null
        && (request.auth.uid == uid
            || firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
                 .data.role_centralhub == 'central_admin');
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size <= 25 * 1024 * 1024;
      allow delete: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
             .data.role_centralhub == 'central_admin';
    }

    // Induction evidence uploads (Phase 5, 2026-05-04).
    // Path: induction_evidence/{uid}/{taskId}/{timestamp}_{filename}
    //   - {uid}    = the mentee's auth uid (matches induction_assignments PK)
    //   - {taskId} = the induction_progress task identifier
    // Owner (mentee) uploads up to 25 MB per file. Mentor + school leader
    // (read from induction_assignments) and central_admin can read/delete.
    // Charter NN2 implications: this is task evidence, not journal — read
    // access is intentionally broader (mentor + school leader) so the parties
    // who sign off the task can verify the evidence.
    match /induction_evidence/{uid}/{taskId}/{filename} {
      allow read: if request.auth != null
        && (request.auth.uid == uid
            || request.auth.uid == firestore.get(
                 /databases/(default)/documents/induction_assignments/$(uid)
               ).data.mentorUid
            || request.auth.uid == firestore.get(
                 /databases/(default)/documents/induction_assignments/$(uid)
               ).data.schoolLeaderUid
            || firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
                 .data.role_centralhub == 'central_admin');
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size <= 25 * 1024 * 1024;
      allow delete: if request.auth != null
        && (request.auth.uid == uid
            || firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
                 .data.role_centralhub == 'central_admin');
    }

    // Careers — candidate CV uploads (Teachers Hub /careers, public form).
    // Path: careers/cv/{positionId}/{timestamp}_{filename}
    // Public write because the apply form runs unauthenticated; size capped
    // at 10 MB and MIME limited to PDF/DOC/DOCX. Read access is gated to
    // signed-in hiring power: central_admin / teachers_admin / hiring_manager / interviewer.
    // (PDF/DOC links also accessible via Firebase getDownloadURL token —
    // the token is included in the application doc's applicant.cvUrl, but
    // those fields are only readable to the same hiring power per the
    // job_applications Firestore rule.)
    match /careers/cv/{positionId}/{filename} {
      allow read: if request.auth != null
        && (
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
               .data.role_centralhub == 'central_admin'
             || firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
                  .data.role_teachershub == 'teachers_admin'
             || (firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
                   .data.th_sub_roles is list
                 && (firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
                       .data.th_sub_roles.hasAny(['hiring_manager','interviewer'])))
           );
      allow write: if request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches(
             'application/pdf|application/msword|application/vnd\\.openxmlformats-officedocument\\.wordprocessingml\\.document');
      allow delete: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
             .data.role_centralhub == 'central_admin';
    }
  }
}
