rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /section-images/{sectionId}/{subId}/{filename} {
      allow read: if request.auth != null;
      allow write, delete: if request.auth != null
        && (firestore.get(
              /databases/(default)/documents/users/$(request.auth.uid)
            ).data.role_academichub == 'academic_admin'
           || firestore.get(
                /databases/(default)/documents/users/$(request.auth.uid)
              ).data.role_centralhub == 'central_admin');
    }
    match /pacing-assessments/{collection}/{chapterId}/{filename} {
      allow read: if request.auth != null;
      allow write, delete: if request.auth != null
        && firestore.get(
             /databases/(default)/documents/users/$(request.auth.uid)
           ).data.role_centralhub == 'central_admin';
    }
    // Orientation page is public — allow unauthenticated photo uploads (images, max 5 MB)
    match /orientation_photos/{filename} {
      allow read: if true;
      allow write: if request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if false;
    }

    // Personal notes attachments (CH dashboard widget + /notes page).
    // Path: user_notes/{uid}/{noteId}/{timestamp}_{filename}
    // Owner uploads + deletes; up to 10 MB per file. Read access widens
    // to all signed-in CH users when the parent Firestore note is
    // public — we can't gate Storage by Firestore field directly, so we
    // accept the widened read here and rely on the file URL only being
    // surfaced through the (rule-gated) Firestore note doc. Files for
    // private notes are still protected because their URLs aren't in
    // any other user's note doc.
    match /user_notes/{uid}/{noteId}/{filename} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null
                       && request.auth.uid == uid
                       && request.resource.size <= 10 * 1024 * 1024;
      allow delete: if request.auth != null
                       && request.auth.uid == uid;
    }

    // Competency evidence uploads (Teachers Hub + Academic Hub portfolios).
    // Path: competency_evidence/{platform}/{uid}/{timestamp}_{filename}
    //   - {platform} = 'teachers' | 'academic'
    //   - {uid}      = the submitting user's auth uid
    // Owner uploads up to 25 MB per file. central_admin can read/delete for review.
    match /competency_evidence/{platform}/{uid}/{filename} {
      // Read: owner, or any CH user (admin or central_user reviewer).
      // Since 2026-05-20 page-access UI gates who reaches /competency-admin;
      // rule layer trusts the page-access decision.
      allow read: if request.auth != null
        && (request.auth.uid == uid
            || firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
                 .data.role_centralhub in ['central_admin', 'central_user']);
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size <= 25 * 1024 * 1024;
      allow delete: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
             .data.role_centralhub == 'central_admin';
    }

    // Induction evidence uploads (Phase 5, 2026-05-04).
    // Path: induction_evidence/{uid}/{taskId}/{timestamp}_{filename}
    //   - {uid}    = the mentee's auth uid (matches induction_assignments PK)
    //   - {taskId} = the induction_progress task identifier
    // Owner (mentee) uploads up to 25 MB per file. Mentor + school leader
    // (read from induction_assignments) and central_admin can read/delete.
    // Charter NN2 implications: this is task evidence, not journal — read
    // access is intentionally broader (mentor + school leader) so the parties
    // who sign off the task can verify the evidence.
    match /induction_evidence/{uid}/{taskId}/{filename} {
      allow read: if request.auth != null
        && (request.auth.uid == uid
            || request.auth.uid == firestore.get(
                 /databases/(default)/documents/induction_assignments/$(uid)
               ).data.mentorUid
            || request.auth.uid == firestore.get(
                 /databases/(default)/documents/induction_assignments/$(uid)
               ).data.schoolLeaderUid
            || firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
                 .data.role_centralhub == 'central_admin');
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size <= 25 * 1024 * 1024;
      allow delete: if request.auth != null
        && (request.auth.uid == uid
            || firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
                 .data.role_centralhub == 'central_admin');
    }

    // Careers — candidate CV uploads (Teachers Hub /careers, public form).
    // Path: careers/cv/{positionId}/{timestamp}_{filename}
    // Public write because the apply form runs unauthenticated; size capped
    // at 10 MB and MIME limited to PDF/DOC/DOCX. Read access is gated to
    // signed-in hiring power: central_admin / teachers_admin / hiring_manager / interviewer.
    // (PDF/DOC links also accessible via Firebase getDownloadURL token —
    // the token is included in the application doc's applicant.cvUrl, but
    // those fields are only readable to the same hiring power per the
    // job_applications Firestore rule.)
    match /careers/cv/{positionId}/{filename} {
      allow read: if request.auth != null
        && (
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
               .data.role_centralhub == 'central_admin'
             || firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
                  .data.role_teachershub == 'teachers_admin'
             || (firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
                   .data.th_sub_roles is list
                 && (firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
                       .data.th_sub_roles.hasAny(['hiring_manager','interviewer'])))
           );
      // Public write — only enforces size cap. MIME-type checks were
      // unreliable at this layer (browsers vary in the Content-Type they
      // attach to .pdf/.doc uploads, especially on Windows; rules return
      // 403 even for legitimate PDFs). Client-side validation in
      // careers-apply.html already restricts the file picker + drag-drop
      // to PDF/DOC/DOCX before the upload starts. Server-side, an
      // attacker who skipped the picker would just be uploading a 10 MB
      // file to a path readable only by hiring_manager/interviewer/admin.
      allow write: if request.resource.size <= 10 * 1024 * 1024;
      allow delete: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
             .data.role_centralhub == 'central_admin';
    }

    // User profile uploads — profile photo + CV (Teachers Hub /settings).
    // Path: user_profile/{uid}/{kind}/{timestamp}_{filename}
    //   - {uid}  = the owning user's auth uid
    //   - {kind} = 'photo' (image, ≤5 MB) | 'cv' (PDF/DOC/DOCX, ≤10 MB)
    // Read is open to any signed-in user (photos appear in directory, CVs
    // are linkable from the user's profile). Owner-only write/delete.
    // MIME / size enforcement happens client-side in settings.html — server
    // rule keeps a hard ≤10 MB ceiling so a tampered client can't blow the
    // bucket up.
    match /user_profile/{uid}/{kind}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size <= 10 * 1024 * 1024;
      allow delete: if request.auth != null
        && (request.auth.uid == uid
            || firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
                 .data.role_centralhub == 'central_admin');
    }

    // Chapter test diagram pool — reusable images attached to one or
    // more chapter_test_items (and, by extension, ease_items in the
    // future). Path mirrors the IGCSE Tools original layout so the
    // 463-diagram migration (2026-05-12) is path-preserving:
    //   diagrams/{subjectId}/{filename}
    //     - subjectId: 'biology' | 'math' | 'physics' | …
    //     - filename:   imageN.png (legacy) | {ts}_{name}.{ext} (new)
    // Read open to any signed-in authorised user (diagrams render
    // inside chapter test attempts + bank previews). Write/delete
    // restricted to admin + CH coordinator — mirrors
    // chapter_test_items authoring boundary. ≤5 MB, image/* only.
    match /diagrams/{subjectId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
              .data.role_centralhub == 'central_admin'
            || (firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
                  .data.role_centralhub == 'central_user'
                && firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
                     .data.ch_sub_roles is list
                && firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
                     .data.ch_sub_roles.hasAny(['coordinator'])))
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
             .data.role_centralhub == 'central_admin';
    }

    // Practice bank diagrams (2026-05-12). Migrated from IGCSE Tools
    // (`igcse-tools.firebasestorage.app`) into the CH bucket at the
    // path `practice-diagrams/{subjectId}/{filename}` by the
    // `scripts/migration/copy-igcse-math-images-to-ch-bucket.js`
    // pre-step before the `practice_questions` Firestore import runs.
    //
    // Read is open to any signed-in user (including active students)
    // because the SH gamification UI fetches images directly via
    // `diagramUrl`. Write/delete mirror the `/diagrams` boundary:
    // admin + CH coordinator can write; admin-only delete. ≤5 MB,
    // image/* only.
    match /practice-diagrams/{subjectId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
              .data.role_centralhub == 'central_admin'
            || (firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
                  .data.role_centralhub == 'central_user'
                && firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
                     .data.ch_sub_roles is list
                && firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
                     .data.ch_sub_roles.hasAny(['coordinator'])))
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
             .data.role_centralhub == 'central_admin';
    }

    // Department Office artifact uploads (2026-05-19) — per-subject
    // living documents (Annual Plan, DTP Report, Department Handbook,
    // Subject Policy) attached to department_artifacts.fileUrl.
    // Path: specialist_artifacts/{subjectId}/{timestamp}_{filename}
    //   - subjectId: one of 'math' | 'biology' | 'chemistry' | 'physics'
    //                | 'science' | 'english' | 'bahasa' | 'religion'
    // Read open to any signed-in user with dept-office membership
    // (central_admin OR ch_sub_roles ∈ {director, coordinator}).
    // Write/delete same boundary. ≤25 MB, MIME limited to PDF / Word /
    // image (PDF is the typical artifact format, Word for collaborative
    // editing, image for occasional reference cards).
    match /specialist_artifacts/{subjectId}/{filename} {
      function isDeptOfficeMember() {
        let u = firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
        return u.role_centralhub == 'central_admin'
            || (u.role_centralhub == 'central_user'
                && u.ch_sub_roles is list
                && u.ch_sub_roles.hasAny(['director','coordinator']));
      }
      allow read: if request.auth != null && isDeptOfficeMember();
      allow write: if request.auth != null
        && isDeptOfficeMember()
        && request.resource.size <= 25 * 1024 * 1024
        && (request.resource.contentType.matches('application/pdf')
            || request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.*')
            || request.resource.contentType.matches('application/msword')
            || request.resource.contentType.matches('image/.*'));
      allow delete: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
             .data.role_centralhub == 'central_admin';
    }

    // Mail-composer image embeds. Quill's "image" toolbar button uploads
    // here instead of inlining base64 — Gmail silently drops data:image
    // URIs in newsletters, but external <img src=https://...> renders
    // inline like any normal email image.
    // Path: mail_images/{adminUid}/{timestamp}_{filename}
    //   - read = PUBLIC (every recipient must load the image without auth)
    //   - write = central_admin only, ≤5 MB, image/* only
    match /mail_images/{adminUid}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == adminUid
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
             .data.role_centralhub == 'central_admin'
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid))
             .data.role_centralhub == 'central_admin';
    }
  }
}
