rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Domain-based check: @eduversal.org emails
    function isEduversal() {
      return isSignedIn() &&
             request.auth.token.email.matches('.*@eduversal\\.org$');
    }

    // School teachers - any @*.sch.id Google account (Academic Hub / Teachers Hub)
    function isSchoolUser() {
      return isSignedIn() &&
             request.auth.token.email.matches('.*@.*\\.sch\\.id');
    }

    // Manually-added users sign in via email/password - Firebase sets
    // sign_in_provider = 'password' for these accounts.
    function isEmailPasswordUser() {
      return isSignedIn() &&
             request.auth.token.firebase.sign_in_provider == 'password';
    }

    // Authorized = @eduversal.org domain OR school domain OR manually-added email/password account
    function isAuthorized() {
      return isEduversal() || isSchoolUser() || isEmailPasswordUser();
    }

    // Helper: read the caller's Firestore profile
    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthorized() && userProfile().role_centralhub == 'central_admin';
    }

    function isCHCoordinator() {
      return isAuthorized() &&
             userProfile().role_centralhub == 'central_user' &&
             userProfile().ch_sub_roles.hasAny(['coordinator']);
    }

    // Academic Hub admin: central_admin or academic_admin can create/edit/delete AH content
    function isAHAdmin() {
      return isAuthorized() && (
        userProfile().role_centralhub  == 'central_admin'  ||
        userProfile().role_academichub == 'academic_admin'
      );
    }

    function isModerator() {
      return isAuthorized() && (
        userProfile().role_centralhub  == 'central_admin'  ||
        userProfile().role_academichub == 'academic_admin' ||
        userProfile().role_academichub == 'academic_user'
      );
    }

    function isCentralUser() {
      return isAuthorized() && (
        userProfile().role_centralhub == 'central_admin' ||
        userProfile().role_centralhub == 'central_user'
      );
    }

    function isAcademicUser() {
      return isAuthorized() && (
        userProfile().role_academichub == 'academic_admin' ||
        userProfile().role_academichub == 'academic_user'
      );
    }

    function isTeachersUser() {
      return isAuthorized() && (
        userProfile().role_teachershub == 'teachers_admin' ||
        userProfile().role_teachershub == 'teachers_user'
      );
    }

    function isTHAdmin() {
      return isAuthorized() && (
        userProfile().role_centralhub  == 'central_admin' ||
        userProfile().role_teachershub == 'teachers_admin'
      );
    }

    function canAccessPlatform(platform) {
      return (
        (platform == 'centralhub'  && isCentralUser()) ||
        (platform == 'academichub' && isAcademicUser()) ||
        (platform == 'teachershub' && isTeachersUser())
      );
    }

    function surveyHasPlatform(surveyData, platform) {
      return (
        (
          ('platforms' in surveyData) &&
          surveyData.platforms is list &&
          surveyData.platforms.hasAny([platform])
        ) ||
        (
          !('platforms' in surveyData) &&
          platform == 'centralhub'
        )
      );
    }

    function canReadSurvey(surveyData) {
      return isAdmin() || (
        isAuthorized() && (
          (surveyHasPlatform(surveyData, 'centralhub')  && isCentralUser()) ||
          (surveyHasPlatform(surveyData, 'academichub') && isAcademicUser()) ||
          (surveyHasPlatform(surveyData, 'teachershub') && isTeachersUser())
        )
      );
    }

    function surveyExists(surveyId) {
      return exists(/databases/$(database)/documents/surveys/$(surveyId));
    }

    function surveyData(surveyId) {
      return get(/databases/$(database)/documents/surveys/$(surveyId)).data;
    }

    function surveyIsOpenForResponses(surveyId) {
      return (
        surveyExists(surveyId) &&
        canReadSurvey(surveyData(surveyId)) &&
        (
          !('status' in surveyData(surveyId)) ||
          surveyData(surveyId).status == 'published'
        ) &&
        (
          !('allowResponses' in surveyData(surveyId)) ||
          surveyData(surveyId).allowResponses == true
        )
      );
    }

    function isValidResponsePayload(data) {
      return (
        data.userId == request.auth.uid &&
        data.surveyId is string &&
        data.platform is string &&
        data.answers is list &&
        data.platform in ['centralhub', 'academichub', 'teachershub'] &&
        canAccessPlatform(data.platform) &&
        surveyIsOpenForResponses(data.surveyId) &&
        surveyHasPlatform(surveyData(data.surveyId), data.platform)
      );
    }

    // -- users -----------------------------------------------
    match /users/{uid} {
      // Any signed-in user can read/write their own doc
      // (covers school-domain Teachers Hub / Academic Hub users logging in via Google)
      allow get:    if isSignedIn() && (request.auth.uid == uid || isAdmin());
      // List (collection query) for CentralHub console (central_admin),
      // AH appraisal teacher search (academic_admin), and CH coordinators
      // who need to view per-teacher pacing progress.
      allow list:   if isAdmin() || isAHAdmin() || isCHCoordinator();
      allow write:  if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    // -- schools ---------------------------------------------
    match /schools/{schoolId} {
      allow read:   if isAuthorized();
      allow create, update, delete: if isAdmin();

      // classes subcollection — any authorised user can read/create/update
      // (teachers add new classes for their school); only admins can delete
      match /classes/{classId} {
        allow read:   if isAuthorized();
        allow create, update: if isSignedIn();
        allow delete: if isAdmin();
      }
    }

    // -- staff -----------------------------------------------
    match /staff/{staffId} {
      allow read:   if isAuthorized();
      allow create, update, delete: if isAdmin();
    }

    // -- announcements ---------------------------------------
    match /announcements/{annId} {
      allow read:   if isAuthorized();
      allow create, update, delete: if isAdmin();

      // comments sub-collection (used by Academic Hub & Teachers Hub)
      match /comments/{commentId} {
        allow read:   if isAuthorized();
        allow create: if isAuthorized()
                         && request.resource.data.authorId == request.auth.uid;
        allow delete: if isAdmin()
                         || (isAuthorized() && resource.data.authorId == request.auth.uid);
        allow update: if false;
      }
    }

    // -- surveys (cross-platform) ----------------------------
    match /surveys/{surveyId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // -- survey_responses ------------------------------------
    match /survey_responses/{responseId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
                       isValidResponsePayload(request.resource.data);

      allow update: if isSignedIn() &&
                       resource.data.userId == request.auth.uid &&
                       isValidResponsePayload(request.resource.data) &&
                       request.resource.data.userId == resource.data.userId &&
                       request.resource.data.surveyId == resource.data.surveyId &&
                       request.resource.data.platform == resource.data.platform;

      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // -- central_documents -----------------------------------
    match /central_documents/{docId} {
      allow read:   if isAuthorized();
      allow create, update, delete: if isAdmin();
    }

    // -- central_certificates --------------------------------
    match /central_certificates/{docId} {
      allow read:   if isAuthorized();
      allow create, update, delete: if isAdmin();
    }

    // -- calendar_events (Academic Calendar admin-managed events) --
    match /calendar_events/{docId} {
      allow read:                    if isAuthorized();
      allow create, update, delete:  if isAdmin();
    }

    // -- calendar_settings (Single-doc academic year config: yearStart, totalWeeks, terms) --
    match /calendar_settings/{docId} {
      allow read:   if isAuthorized();
      allow write:  if isAdmin();
    }

    // -- teaching_schedule (Pre-computed teaching weeks per subject, written by admin Sync) --
    match /teaching_schedule/{docId} {
      allow read:   if isAuthorized();
      allow write:  if isAdmin();
    }

    // -- nav_config (Navbar item order + labels, editable by central_admin) --
    match /nav_config/{docId} {
      allow read:   if isAuthorized();
      allow write:  if isAdmin();
    }

    // -- weekly_essentials (Standing recurring checklist items, per platform) --
    match /weekly_essentials/{platform} {
      allow read:  if isAuthorized();
      allow write: if isAdmin();
    }

    // -- weekly_templates (Weekly checklist templates) -------
    match /weekly_templates/{docId} {
      allow read:                    if isAuthorized();
      allow create, update, delete:  if isAdmin();
    }

    // -- weekly_progress (Per-user checklist progress) -------
    match /weekly_progress/{docId} {
      allow read:   if isAuthorized();
      allow create, update: if request.auth != null
                            && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // -- school_appraisals (legacy handbook editor) ----------
    match /school_appraisals/{docId} {
      allow read:   if isAuthorized();
      allow write:  if isAdmin();
    }

    // -- school_appraisals_v2 (interactive 5-domain appraisal tool) --
    // Read:   any Central Hub or Academic Hub user
    // Create: central_admin only (creates the appraisal record for a school)
    // Update: central_admin can update any field (review, recommendations);
    //         academic_user/admin with schoolId match can update ratings/evidence/strengths/improvements
    // Delete: central_admin only
    match /school_appraisals_v2/{docId} {
      allow read:   if isCentralUser() || isAcademicUser();
      allow create: if isAdmin()
                    || (isAcademicUser()
                        && request.resource.data.schoolId ==
                           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId);
      allow update: if isAdmin()
                    || (isAcademicUser()
                        && resource.data.schoolId ==
                           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId);
      allow delete: if isAdmin();
    }

    // -- appraisal_cycles (Central Hub cycle management) ------
    // Read: any authenticated user (apps need to know if a cycle is open)
    // Create/Update: central_admin only
    // Delete: central_admin only
    match /appraisal_cycles/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    // -- teacher_appraisals (Formal Appraisal v2.0) ----------
    // Create:  academic_admin or academic_user with school_principal/academic_coordinator/cambridge_coordinator sub-role
    // Read:    the teacher who owns it (teacherUid == uid), any AH admin, any TH admin, central_admin
    // Update:  appraiser (AH admin/sub-role) can update any field while status != finalised;
    //          teacher can update teacherResponse + status (shared → acknowledged) only
    // Delete:  central_admin only
    match /teacher_appraisals/{docId} {
      allow read: if isAdmin()
                  || isCentralUser()
                  || isAHAdmin()
                  || isTeachersAdmin()
                  || (isTeachersUser() && resource.data.teacherUid == request.auth.uid)
                  || (isAcademicUser() && resource.data.appraiserUid == request.auth.uid);
      allow create: if isAHAdmin()
                    || (isAcademicUser()
                        && userProfile().ah_sub_roles.hasAny(['school_principal', 'academic_coordinator', 'cambridge_coordinator']));
      allow update: if isAdmin()
                    || isAHAdmin()
                    || (isAcademicUser()
                        && resource.data.appraiserUid == request.auth.uid
                        && userProfile().ah_sub_roles.hasAny(['school_principal', 'academic_coordinator', 'cambridge_coordinator']))
                    || (isTeachersUser()
                        && resource.data.teacherUid == request.auth.uid
                        && resource.data.status == 'shared'
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['teacherResponse', 'status', 'updatedAt']))
                    || (isTeachersUser()
                        && resource.data.teacherUid == request.auth.uid
                        && resource.data.status == 'finalised'
                        && !resource.data.disputed
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['disputed', 'disputeReason', 'disputedAt', 'disputeStatus']));
      allow delete: if isAdmin();
    }

    // -- teacher_self_appraisals (Teacher Self-Appraisal) -----
    // Create/update: the teacher themselves (uid match), draft or submitted
    // Read:          the teacher, any AH admin/appraiser sub-role, TH admin, central_admin
    // Delete:        central_admin only
    match /teacher_self_appraisals/{docId} {
      allow read: if isAdmin()
                  || isAHAdmin()
                  || isTeachersAdmin()
                  || (isAcademicUser() && userProfile().ah_sub_roles.hasAny(['school_principal', 'academic_coordinator', 'cambridge_coordinator']))
                  || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && (isTeachersUser() || isTeachersAdmin());
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid
                    && resource.data.status != 'submitted'
                    && (isTeachersUser() || isTeachersAdmin());
      allow delete: if isAdmin();
    }

    // -- teacher_walkthroughs (Classroom Walkthrough v2.0) ---
    // Create:  academic_admin, or academic_user with school_principal/academic_coordinator/cambridge_coordinator sub-role
    // Read:    the teacher (teacherUid), appraiser (observerUid), AH admin, TH admin, central_admin
    // Update:  observer who created it, or AH admin (within same academic year — no cross-year edits)
    // Delete:  central_admin or AH admin only
    match /teacher_walkthroughs/{docId} {
      allow read: if isAdmin()
                  || isCentralUser()
                  || isAHAdmin()
                  || isTeachersAdmin()
                  || (isTeachersUser() && resource.data.teacherUid == request.auth.uid)
                  || (isAcademicUser() && resource.data.observerUid == request.auth.uid);
      allow create: if isAHAdmin()
                    || (isAcademicUser()
                        && userProfile().ah_sub_roles.hasAny(['school_principal', 'academic_coordinator', 'cambridge_coordinator']));
      allow update: if isAdmin()
                    || isAHAdmin()
                    || (isAcademicUser()
                        && resource.data.observerUid == request.auth.uid
                        && userProfile().ah_sub_roles.hasAny(['school_principal', 'academic_coordinator', 'cambridge_coordinator']));
      allow delete: if isAdmin() || isAHAdmin();
    }

    // -- ease_system -----------------------------------------
    match /ease_system/{docId} {
      allow read:   if isAuthorized();
      allow write:  if isAdmin();
    }

    // -- documents (Academic Hub) ----------------------------
    match /documents/{docId} {
      allow read:   if isAuthorized();
      allow create, update, delete: if isAHAdmin();
    }

    // -- doc_likes (Academic Hub) ----------------------------
    match /doc_likes/{likeId} {
      allow read:  if isAuthorized();
      allow write: if isAuthorized() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthorized();
    }

    // -- doc_ratings (Academic Hub) --------------------------
    match /doc_ratings/{ratingId} {
      allow read:  if isAuthorized();
      allow write: if isAuthorized() && request.resource.data.userId == request.auth.uid;
    }

    // -- library (Academic Hub) ------------------------------
    match /library/{resourceId} {
      allow read:   if isAuthorized();
      allow create, delete: if isAHAdmin();
      allow update: if isAHAdmin();
    }

    // -- prompts (Academic Hub - AI Prompts) -----------------
    match /prompts/{promptId} {
      allow read:   if isAuthorized();
      allow create, delete: if isAHAdmin();
      // Any user can increment the `uses` counter; only admin can edit other fields
      allow update: if isAHAdmin()
                    || (isAuthorized()
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uses']));
    }

    // -- feedbacks -------------------------------------------
    match /feedbacks/{fbId} {
      allow create: if isAuthorized();
      allow read, update, delete: if isAdmin();
    }

    // -- feedback (Central Hub index feedback modal) ---------
    match /feedback/{fbId} {
      allow create: if isAuthorized();
      allow read, update, delete: if isAdmin();
    }

    // -- timeline_activities (Academic Calendar) -------------
    match /timeline_activities/{actId} {
      allow read:   if isAuthorized();
      allow create, update: if isModerator();
      allow delete: if isAdmin();
    }

    // -- timeline_completions (Academic Calendar) ------------
    match /timeline_completions/{compId} {
      allow read:   if isAuthorized();
      allow write:  if isAuthorized() && request.resource.data.userId == request.auth.uid;
    }

    // Teachers Hub admin: teachers_admin role
    function isTeachersAdmin() {
      return isAuthorized() && userProfile().role_teachershub == 'teachers_admin';
    }

    // -- Cambridge syllabus reference data (all levels: IGCSE, AS/A-Level, Checkpoint) -----------------------
    // Read open to any authenticated user (Teachers Hub, Academic Hub, Central Hub all need this).
    match /cambridge_syllabus/{docId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // -- Curated Stage 7→8→9 progression mapping (one doc per subject code).
    // Used by the Progression Grid tab on checkpoint pacing pages.
    match /cambridge_syllabus_progression/{docId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // -- IGCSE / A-Level / Checkpoint pacing structures ------
    // Writers: central_admin or CH coordinator sub-role (lesson hours edit)
    match /math_pacing/{docId} {
      allow read:  if isAuthorized();
      allow write: if isAdmin() || isCHCoordinator();
    }

    match /biology_pacing/{docId} {
      allow read:  if isAuthorized();
      allow write: if isAdmin() || isCHCoordinator();
    }

    match /chemistry_pacing/{docId} {
      allow read:  if isAuthorized();
      allow write: if isAdmin() || isCHCoordinator();
    }

    match /physics_pacing/{docId} {
      allow read:  if isAuthorized();
      allow write: if isAdmin() || isCHCoordinator();
    }

    match /asalevel_math_pacing/{docId} {
      allow read:  if isAuthorized();
      allow write: if isTeachersAdmin() || isAdmin() || isCHCoordinator();
    }

    match /asalevel_biology_pacing/{docId} {
      allow read:  if isAuthorized();
      allow write: if isTeachersAdmin() || isAdmin() || isCHCoordinator();
    }

    match /asalevel_chemistry_pacing/{docId} {
      allow read:  if isAuthorized();
      allow write: if isTeachersAdmin() || isAdmin() || isCHCoordinator();
    }

    match /asalevel_physics_pacing/{docId} {
      allow read:  if isAuthorized();
      allow write: if isTeachersAdmin() || isAdmin() || isCHCoordinator();
    }

    match /checkpoint_math_pacing/{docId} {
      allow read:  if isAuthorized();
      allow write: if isTeachersAdmin() || isAdmin() || isCHCoordinator();
    }

    match /checkpoint_english_pacing/{docId} {
      allow read:  if isAuthorized();
      allow write: if isTeachersAdmin() || isAdmin() || isCHCoordinator();
    }

    match /checkpoint_science_pacing/{docId} {
      allow read:  if isAuthorized();
      allow write: if isTeachersAdmin() || isAdmin() || isCHCoordinator();
    }

    match /primary_math_pacing/{docId} {
      allow read:  if isAuthorized();
      allow write: if isTeachersAdmin() || isAdmin() || isCHCoordinator();
    }

    match /primary_english_pacing/{docId} {
      allow read:  if isAuthorized();
      allow write: if isTeachersAdmin() || isAdmin() || isCHCoordinator();
    }

    match /primary_science_pacing/{docId} {
      allow read:  if isAuthorized();
      allow write: if isTeachersAdmin() || isAdmin() || isCHCoordinator();
    }

    // -- userProgress (per-user pacing progress) -------------
    // Academic Hub users can read progress of teachers at their same school
    // (for the Syllabus Coverage dashboard). Uses schoolId field on user profiles.
    function isAHUserAtSameSchool(targetUid) {
      return isAcademicUser() &&
        get(/databases/$(database)/documents/users/$(targetUid)).data.schoolId ==
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId;
    }

    match /userProgress/{uid} {
      allow get:   if (isSignedIn() && request.auth.uid == uid)
                   || isAdmin()
                   || isCHCoordinator()
                   || isAHUserAtSameSchool(uid);
      allow list:  if isAdmin() || isCHCoordinator() || isAcademicUser();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // -- activity_projects (Activities board) ----------------
    match /activity_projects/{docId} {
      allow read:                    if isAuthorized();
      allow create, update, delete:  if isAdmin();
    }

    // -- activity_tasks (Activities board tasks) -------------
    // All authorized users can update (for status changes).
    // Only admins can create or delete tasks.
    match /activity_tasks/{docId} {
      allow read:           if isAuthorized();
      allow create, delete: if isAdmin();
      allow update:         if isAuthorized();
    }

    // -- activity_groups (Assignee groups for Activities) ----
    match /activity_groups/{docId} {
      allow read:                    if isAuthorized();
      allow create, update, delete:  if isAdmin();
    }

    // -- section_overrides (Academic Standards inline edits) -
    match /section_overrides/{sectionId} {
      allow read: if isAuthorized();
      allow write: if isAHAdmin();

      match /subsections/{subId} {
        allow read: if isAuthorized();
        allow write: if isAHAdmin();
      }
    }

    // -- partner_schools (School Performance KPI) ------------
    // Read: any Academic Hub user (for school selector in KPI form)
    //       also Central Hub users (console schoolId dropdown)
    // Write: isAHAdmin() already covers central_admin + academic_admin
    match /partner_schools/{schoolId} {
      allow read:  if isAcademicUser() || isCentralUser();
      allow write: if isAHAdmin();
    }

    // -- kpi_config (School Performance KPI - criteria definitions) --
    // Write: isAHAdmin() covers central_admin (kpi-admin.html) + academic_admin
    match /kpi_config/{kpiId} {
      allow read:  if isAcademicUser();
      allow write: if isAHAdmin();
    }

    // -- kpi_settings (School Performance KPI - semester settings) ---
    // Write: isAHAdmin() covers central_admin (kpi-admin.html) + academic_admin
    match /kpi_settings/{semId} {
      allow read:  if isAcademicUser();
      allow write: if isAHAdmin();
    }

    // -- teacher_kpi_config (Teacher KPI criteria definitions) -------
    // Read: any authorized user (teachers may need to view their KPI criteria)
    // Write: central_admin only (managed from kpi-admin.html)
    match /teacher_kpi_config/{kpiId} {
      allow read:  if isAuthorized();
      allow write: if isAdmin();
    }

    // -- teacher_kpi_settings (Teacher KPI evaluation periods) -------
    // Read: any authorized user
    // Write: central_admin only
    match /teacher_kpi_settings/{periodId} {
      allow read:  if isAuthorized();
      allow write: if isAdmin();
    }

    // -- teacher_kpi_evaluations (Admin evaluations of teacher submissions) --
    // Doc ID = submissionId (same as teacher_kpi_submissions for 1-1 relationship)
    // Read:  central_admin, academic_admin/user (AH evaluators), teachers_admin
    // Write: academic_admin OR academic_user with school_principal/academic_coordinator sub-role
    // Teacher: read only their own evaluation
    match /teacher_kpi_evaluations/{submissionId} {
      allow read: if isAdmin()
                  || isAHAdmin()
                  || isTeachersAdmin()
                  || (isAcademicUser() && userProfile().uid == resource.data.evaluatorInfo.evaluatorUid)
                  || (isTeachersUser() && resource.data.teacherUid == request.auth.uid);
      allow create, update: if isAHAdmin()
                            || (isAcademicUser()
                                && (userProfile().ah_sub_roles.hasAny(['school_principal', 'academic_coordinator'])));
      allow delete: if isAdmin();
    }

    // -- teacher_kpi_submissions (Teacher self-assessment submissions) --
    // Doc ID format: {uid}_{periodId}
    // Read:  any teachers_user (doc ID contains their own uid so they can only
    //        construct their own submissionId); admins and AH evaluators read all
    // Write: teacher who owns it (create + update their own submission)
    // Delete: central_admin only
    match /teacher_kpi_submissions/{submissionId} {
      allow read: if isAdmin()
                  || isTeachersAdmin()
                  || isAHAdmin()
                  || isTeachersUser();
      allow create: if isTeachersUser()
                    && request.resource.data.uid == request.auth.uid;
      allow update: if isTeachersUser()
                    && resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // -- kpi_meeting_proposals (Evaluator proposes meeting date to teacher) --
    // Doc ID: auto
    // Fields: submissionId, teacherUid, proposedDate, time, location, note, status (pending/confirmed/declined)
    // Read:  evaluators (AH admin/user), the teacher whose submission it is, teachers_admin
    // Write: evaluators create/update; teacher updates status only
    match /kpi_meeting_proposals/{proposalId} {
      allow read: if isAdmin()
                  || isAHAdmin()
                  || isTeachersAdmin()
                  || (isAcademicUser() && resource.data.evaluatorUid == request.auth.uid)
                  || (isTeachersUser() && resource.data.teacherUid == request.auth.uid);
      allow create: if isAHAdmin()
                    || (isAcademicUser()
                        && userProfile().ah_sub_roles.hasAny(['school_principal', 'academic_coordinator']));
      allow update: if isAHAdmin()
                    || (isAcademicUser()
                        && userProfile().ah_sub_roles.hasAny(['school_principal', 'academic_coordinator']))
                    || (isTeachersUser()
                        && resource.data.teacherUid == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'respondedAt', 'respondedBy']));
      allow delete: if isAdmin();
    }

    // -- school_performance_kpi (KPI data submissions) -------
    // Structure: school_performance_kpi/{semId}/schools/{schoolId}
    // Read:  academic_admin sees all; academic_user sees only their own school
    // Write: academic_admin always; academic_user only if their schoolId matches
    match /school_performance_kpi/{semId}/schools/{schoolId} {
      allow read: if isAHAdmin()
                  || (isAcademicUser()
                      && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == schoolId);
      allow write: if isAHAdmin()
                   || (isAcademicUser()
                       && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == schoolId);
    }

    // -- ah_categories (Academic Hub dashboard category config) --
    match /ah_categories/{catId} {
      allow read:                   if isAcademicUser();
      allow create, update, delete: if isAHAdmin();
    }

    // -- th_resource_sections (Teachers Hub index resource sections) --
    match /th_resource_sections/{secId} {
      allow read:                   if isTeachersUser();
      allow create, update, delete: if isTeachersAdmin();
    }

    // -- networkAudits (School Network Security Audit results) --
    match /networkAudits/{auditId} {
      allow create: if isAuthorized() && request.resource.data.testerUid == request.auth.uid;
      allow read:   if isAdmin() || (isAuthorized() && resource.data.testerUid == request.auth.uid);
      allow list:   if isAdmin();
      allow delete: if isAdmin();
      allow update: if false;
    }

    // -- platform_usage (login analytics, written by all auth-guards) --
    match /platform_usage/{docId} {
      // Any authenticated user can write their own login event
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      // Only central_admin can read (for analytics dashboard)
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // -- pathwaySubmissions (Cambridge Pathway Simulator - public) --
    match /pathwaySubmissions/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // -- orientation_resources (public handbook/video/book list) --
    // Read: anyone (no auth required — public orientation page)
    // Write: central_admin only
    match /orientation_resources/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // -- orientation_questions (competency quiz questions) --
    // Read: anyone (public orientation page)
    // Write: central_admin only
    match /orientation_questions/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // -- orientation_registrations (submitted applications) --
    // Create: anyone (public form submission)
    // Read/update/delete: central_admin only
    match /orientation_registrations/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // -- school_events (Partner Schools Event Calendar) ----------
    // Read: any authorized user
    // Write: any Central Hub user (central_user or central_admin)
    match /school_events/{eventId} {
      allow read:                   if isAuthorized();
      allow create, update, delete: if isCentralUser();
    }

    // -- cambridge_calendar (exam deadline dates per year+series) --
    // Read: any authorized user (AH, TH, CH all need to view)
    // Write: central_admin only
    match /cambridge_calendar/{docId} {
      allow read:  if isAuthorized();
      allow write: if isAdmin();
    }

    // -- school_visits (Visit & Audit Management) ------------
    // Read: any Central Hub user
    // Write (create/update/delete): central_admin only
    match /school_visits/{visitId} {
      allow read:                   if isCentralUser();
      allow create, update, delete: if isAdmin();
    }

    // -- kpi_school_submissions (School KPI submissions reviewed by HQ) --
    // Read: central_admin reads all; academic_admin reads all;
    //       academic_user reads only their own school's submission
    // Write (create/update): academic_admin or academic_user for their own school
    // Status updates (approve/reject/under_review): central_admin only
    match /kpi_school_submissions/{submId} {
      allow read: if isAdmin() || isAHAdmin()
                  || (isAcademicUser()
                      && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == resource.data.schoolId);
      allow create: if isAHAdmin()
                    || (isAcademicUser()
                        && request.resource.data.schoolId ==
                           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId);
      allow update: if isAdmin()
                    || isAHAdmin()
                    || (isAcademicUser()
                        && resource.data.schoolId ==
                           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId);
      allow delete: if isAdmin();
    }

    // -- announcement_reads (read-receipt tracking) ----------
    // Doc ID: {annId}__{uid}
    // Any authorized user can write their own read receipt; admin reads all
    match /announcement_reads/{readId} {
      allow read:   if isAdmin();
      allow create, update: if isAuthorized()
                            && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // -- teacher_contacts (Unregistered teacher mailing list) --
    // Read: central_admin only (mail-composer.html)
    // Write: central_admin only
    match /teacher_contacts/{contactId} {
      allow read, write: if isAdmin();
    }

    // -- mail_campaigns (Newsletter campaign history) --------
    // Written by Railway mail service via Admin SDK (bypasses rules).
    // Central Hub frontend only reads (mail-composer.html history table).
    match /mail_campaigns/{campaignId} {
      allow read: if isAdmin();
      allow write: if false; // Admin SDK only
    }

    // -- competency_evidence (Teacher & Admin evidence submissions) --
    // Create:  the owner (any authorized teacher or academic user)
    // Read:    owner reads their own; central_admin reads all
    // Update:  central_admin only (to set status, reviewerNote, reviewedBy)
    // Delete:  central_admin only
    match /competency_evidence/{evId} {
      allow create: if isAuthorized()
                    && request.resource.data.uid == request.auth.uid;
      allow read:   if isAdmin()
                    || (isAuthorized() && resource.data.uid == request.auth.uid);
      allow list:   if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();

      // comments sub-collection: reviewer thread visible to owner and admins
      match /comments/{commentId} {
        allow read:   if isAdmin()
                      || (isAuthorized() && get(/databases/$(database)/documents/competency_evidence/$(evId)).data.uid == request.auth.uid);
        allow create: if isAdmin()
                      && request.resource.data.authorUid == request.auth.uid;
        allow delete: if isAdmin();
        allow update: if false;
      }
    }

    // -- user_competencies (Per-user earned competency tracking) --
    // Doc ID = uid
    // User can read/write their own doc (for material done tracking).
    // Admin can read/write any doc (for approving earned levels).
    match /user_competencies/{uid} {
      allow read:   if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write:  if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    // -- content_overrides_academic (Admin-edited reading text for Academic Hub) --
    // Doc ID = "{compId}_{lvl}" e.g. "evsi-1_awareness"
    match /content_overrides_academic/{docId} {
      allow read:  if isAuthorized();
      allow write: if isAHAdmin();
    }

    // -- content_overrides_teachers (Admin-edited reading text for Teachers Hub) --
    // Doc ID = "{compId}_{lvl}" e.g. "smc-1_awareness"
    match /content_overrides_teachers/{docId} {
      allow read:  if isAuthorized();
      allow write: if isTHAdmin();
    }

    // -- competency_certificates (Issued certificates) -------
    // Create:  central_admin only (issued via competency-admin.html)
    // Read:    owner reads their own; central_admin reads all
    // Update:  central_admin only (revoke flag)
    // Delete:  central_admin only
    match /competency_certificates/{certId} {
      allow create: if isAdmin();
      allow read:   if isAdmin()
                    || (isAuthorized() && resource.data.uid == request.auth.uid);
      allow list:   if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // -- framework_config (Admin-editable sample document links for appraisal framework) --
    // Read:  any authorized Academic Hub or Central Hub user
    // Write: academic_admin or central_admin only
    match /framework_config/{docId} {
      allow read:  if isAuthorized();
      allow write: if isAHAdmin();
    }

    // -- calibration_sessions (Appraiser IRR calibration — Academic Hub) --
    // Doc ID: {uid}_{year}  e.g. "abc123_2025"
    // Read:   owner reads their own; academic_admin reads all (leaderboard)
    // Write:  owner only (setDoc with merge)
    match /calibration_sessions/{docId} {
      allow read:  if isAHAdmin()
                   || (isSignedIn() && isAcademicUser() && resource.data.uid == request.auth.uid);
      allow list:  if isAHAdmin();
      allow write: if isSignedIn() && isAcademicUser()
                   && request.resource.data.uid == request.auth.uid;
    }

    // -- calibration_group_sessions (Real-time group calibration sessions) --
    // Doc ID: 6-char session code (random)
    // Read:   any Academic Hub user (to join by code)
    // Create: any Academic Hub user (facilitator)
    // Update: any Academic Hub user (join as participant, submit scores)
    match /calibration_group_sessions/{sessionCode} {
      allow read:   if isSignedIn() && isAcademicUser();
      allow create: if isSignedIn() && isAcademicUser();
      allow update: if isSignedIn() && isAcademicUser();
    }

    // -- sidebar_config (Central Hub sidebar order) ----------
    // Read: any central hub user (to load their sidebar order)
    // Write: central_admin only
    match /sidebar_config/{docId} {
      allow read:  if isCentralUser();
      allow write: if isAdmin();
    }

    // -- topics (message board) ------------------------------
    match /topics/{topicId} {
      allow read:   if isAuthorized();
      allow create: if isAuthorized();
      allow update: if isAuthorized() &&
                       (resource.data.author == request.auth.token.email || isAdmin());
      allow delete: if isAdmin();

      match /replies/{replyId} {
        allow read:   if isAuthorized();
        allow create: if isAuthorized();
        allow update, delete: if isAdmin();
      }
    }
  }
}
